# 复制为 .env 并填写
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/trauma_heal

# JWT 签名（生产环境请用随机长串）
JWT_SECRET=change-me-in-production

# OpenRouter：https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=deepseek/deepseek-r1
# 双模型路由：长自述 → R1，日常短句 → Chat
OPENROUTER_CHAT_ROUTING=true
OPENROUTER_CHAT_MODEL_DEEP=deepseek/deepseek-r1
OPENROUTER_CHAT_MODEL_FAST=deepseek/deepseek-chat
OPENROUTER_CHAT_DEEP_MIN_CHARS=300
OPENROUTER_CHAT_MAX_TOKENS=3072
OPENROUTER_CHAT_TEMPERATURE=0.65
# OpenRouter reasoning（流式正文，exclude=true 时思考过程不可见）
OPENROUTER_CHAT_REASONING=true
OPENROUTER_CHAT_REASONING_EFFORT=max
# 回复前内部分析 pass（已弃用，默认关闭）
OPENROUTER_CHAT_TWO_PASS=false
OPENROUTER_CHAT_ANALYSIS_MAX_TOKENS=1200
OPENROUTER_CHAT_ANALYSIS_TEMPERATURE=0.4
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_EMBEDDING_DIMENSIONS=2048

# 管理后台 X-Admin-Key
ADMIN_SECRET=

# 可选
# PORT=8000
# HOST=0.0.0.0
# PROMPT_TEMPLATE_DIR=./prompts
