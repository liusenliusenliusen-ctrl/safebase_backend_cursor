# 复制为 .env 并填写。必填项以 app/config.py 为准。
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# OpenRouter：对话与向量均使用该网关 https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=deepseek/deepseek-chat
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# 与数据库 vector 维度一致时填写（如 2048）；不需要则删除本行
OPENROUTER_EMBEDDING_DIMENSIONS=2048

# 可选
# ADMIN_SECRET=
# PROMPT_TEMPLATE_DIR=
# PROMPT_HOT_RELOAD=false
