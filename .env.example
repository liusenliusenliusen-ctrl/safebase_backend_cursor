# 复制为 .env 并填写
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/trauma_heal

# JWT 签名（生产环境请用随机长串）
JWT_SECRET=change-me-in-production

# ========== 对话 API 提供商 ==========
# deepseek = 官方 API（推荐）；openrouter = 聚合网关（fallback）
LLM_CHAT_PROVIDER=deepseek

# --- DeepSeek 官方：双模型路由的实际调用目标 ---
# 深度轮 ← 原 OpenRouter deepseek-r1 + reasoning
# 快轨   ← 原 OpenRouter deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL_DEEP=deepseek-reasoner
DEEPSEEK_CHAT_MODEL_FAST=deepseek-chat

# --- OpenRouter：仅 embedding 必填；LLM_CHAT_PROVIDER=openrouter 时对话也走此通道 ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL_DEEP=deepseek/deepseek-r1
OPENROUTER_CHAT_MODEL_FAST=deepseek/deepseek-chat

# ========== 双模型路由规则（与 API 提供商无关，两通道共用）==========
# 长自述 / 多信号 → DEEPSEEK_CHAT_MODEL_DEEP（或 OR 深度模型）
# 短句 / 寒暄     → DEEPSEEK_CHAT_MODEL_FAST（或 OR 快轨模型）
OPENROUTER_CHAT_ROUTING=true
OPENROUTER_CHAT_DEEP_MIN_CHARS=300
# 深度轮（短但多信号）；intake 长叙述见 DEEP
OPENROUTER_CHAT_MAX_TOKENS=8192
OPENROUTER_CHAT_MAX_TOKENS_DEEP=16384
OPENROUTER_CHAT_MAX_TOKENS_FAST=3072
OPENROUTER_CHAT_TEMPERATURE=0.65
# 仅 OpenRouter 深度轮：reasoning.effort（DeepSeek 用 reasoner 模型即可）
OPENROUTER_CHAT_REASONING=true
OPENROUTER_CHAT_REASONING_EFFORT=max
OPENROUTER_CHAT_TWO_PASS=false
OPENROUTER_CHAT_ANALYSIS_MAX_TOKENS=1200
OPENROUTER_CHAT_ANALYSIS_TEMPERATURE=0.4

# ========== 向量（始终 OpenRouter）==========
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
OPENROUTER_EMBEDDING_DIMENSIONS=2048

# 管理后台 X-Admin-Key
ADMIN_SECRET=

# 可选
# PORT=8000
# HOST=0.0.0.0
# PROMPT_TEMPLATE_DIR=./prompts
